---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "A short note about Stavros Karelis and the work he shares online",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<p>
			I am a developer and curious builder who enjoys thoughtful interfaces, clean systems, and
			sharing what I learn along the way.
		</p>
		<p>
			This site is a personal space for notes, posts, and experiments that I want to keep and return
			to later.
		</p>
		<p>The goal is simple: keep things useful, minimal, and easy to revisit.</p>
	</div>
</PageLayout>
