---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "A clean digital garden for AI, technology, and systems thinking.",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About</h1>
	<div class="prose prose-sm max-w-none">
		<p>
			This website is a digital garden built with Astro and Tailwind CSS, focused on sharp ideas 🧠
			around AI, systems, and modern technology.
		</p>
		<p>What makes it useful:</p>
		<ul class="list-inside list-disc" role="list">
			<li>Fast static delivery with minimal dependencies</li>
			<li>Responsive layout for desktop and mobile</li>
			<li>Clean, readable content styling for notes and posts</li>
			<li>Easy editing with Markdown content collections</li>
			<li>Satori-generated OG images for better sharing</li>
		</ul>
		<p>
			📌 The site is intentionally simple, so ideas can stay clear, precise, and easy to revisit.
		</p>
	</div>
</PageLayout>
